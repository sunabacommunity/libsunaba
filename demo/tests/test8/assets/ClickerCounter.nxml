<?xml version="1.0" encoding="utf-8" ?>
<nxml fullscreen="true" name="clickerCounter">
	<head></head>
	<body>
		<newhaven.ui.Panel
			fullRect="true"
			offsetBottom="10"
			offsetTop="-10"
			offsetLeft="-10"
			offsetRight="10"/>
		<newhaven.ui.CenterContainer
			fullRect="true"
			name="centerContainer">
			<newhaven.ui.VBoxContainer
				name="vboxContainer">
				<newhaven.ui.Label
					name="clickCounterLabel"
					text="You clicked me 0 times!"
					verticalAlignment="1"
					horizontalAlignment="1"/>
				<newhaven.ui.Button
					name="clickerButton"
					text="Click me!"
					alignment="1"/>
			</newhaven.ui.VBoxContainer>
		</newhaven.ui.CenterContainer>
	</body>
</nxml>
